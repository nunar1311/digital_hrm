# syntax=docker/dockerfile:1

# ============================================
# Development Dockerfile
# ============================================
FROM node:20-alpine

RUN apk add --no-cache libc6-compat

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

EXPOSE 3000

CMD ["sh", "-c", "pnpm install && pnpm prisma generate && pnpm dev"]
