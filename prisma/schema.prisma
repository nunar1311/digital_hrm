// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ─── HRM custom fields ───
  employeeCode String? @unique
  departmentId String?
  position     String?
  hrmRole      String  @default("EMPLOYEE") // SUPER_ADMIN, HR_MANAGER, etc.

  // ─── Employee extended fields ───
  // Thông tin cá nhân
  fullName          String?
  dateOfBirth       DateTime?
  gender            String? // MALE, FEMALE, OTHER
  nationalId        String? // CMND/CCCD
  nationalIdDate    DateTime?
  nationalIdPlace   String?
  phone             String?
  personalEmail     String?
  address           String?
  permanentAddress  String?
  nationality       String?  @default("Việt Nam")
  religion          String?
  ethnicity         String?  @default("Kinh")
  maritalStatus     String?  // SINGLE, MARRIED, DIVORCED

  // Thông tin công việc
  jobTitleId       String?
  managerId         String?
  employmentType    String?  @default("FULL_TIME") // FULL_TIME, PART_TIME, CONTRACT, INTERN
  employeeStatus    String?  @default("ACTIVE") // ACTIVE, ON_LEAVE, RESIGNED, TERMINATED
  hireDate          DateTime?
  probationEnd      DateTime?
  resignDate        DateTime?

  // Thông tin ngân hàng
  bankName          String?
  bankAccount       String?
  bankBranch        String?

  // Thông tin BHXH, BHYT, MST
  socialInsuranceNo String?
  healthInsuranceNo String?
  taxCode           String?

  // Trình độ học vấn
  educationLevel    String?  // HIGHSCHOOL, COLLEGE, BACHELOR, MASTER, PHD
  major             String?
  university        String?

  // Metadata
  avatar            String?
  notes             String?

  // Relations
  department        Department? @relation(fields: [departmentId], references: [id])
  manager           User?       @relation("ManagerReports", fields: [managerId], references: [id])
  reports           User[]      @relation("ManagerReports")

  // ─── Better Auth relations ───
  sessions            Session[]
  accounts            Account[]
  members             Member[]
  managedDepartments  Department[]        @relation("DeptManager")
  attendances         Attendance[]
  overtimeRequests    OvertimeRequest[]
  shiftAssignments    ShiftAssignment[]
  attendanceSummaries AttendanceSummary[]
  offboardings        Offboarding[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

// ORGANIZATION (Phòng ban)

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  metadata  String?
  createdAt DateTime @default(now())

  members Member[]

  @@map("organizations")
}

model Member {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           String   @default("member")
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Department {
  id                 String       @id @default(cuid())
  name               String
  code               String       @unique
  logo               String?
  description        String?
  parentId           String?
  secondaryParentIds String[]
  managerId          String? // userId of the department manager
  status             String       @default("ACTIVE")
  sortOrder          Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  parent             Department?  @relation("DeptHierarchy", fields: [parentId], references: [id])
  children           Department[] @relation("DeptHierarchy")
  positions          Position[]
  manager            User?        @relation("DeptManager", fields: [managerId], references: [id])
  jobPostings        JobPosting[]
  users              User[]

  @@map("departments")
}

model Position {
  id           String      @id @default(cuid())
  name         String
  code         String      @unique
  departmentId String?
  level        Int         @default(1)
  description  String?
  department   Department? @relation(fields: [departmentId], references: [id])
  jobPostings JobPosting[]

  @@map("positions")
}

// ─── ATTENDANCE MODULE ───

model Shift {
  id               String            @id @default(cuid())
  name             String // Ca sáng, Ca chiều, Ca hành chính
  code             String            @unique
  startTime        String // "08:00"
  endTime          String // "17:00"
  breakMinutes     Int               @default(60)
  lateThreshold    Int               @default(15) // Số phút cho phép đi muộn trước khi ghi late
  earlyThreshold   Int               @default(15) // Số phút rời sớm trước khi ghi early_leave
  isDefault        Boolean           @default(false)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendances      Attendance[]
  shiftAssignments ShiftAssignment[]
  workCycleEntries WorkCycleEntry[]

  @@map("shifts")
}

model ShiftAssignment {
  id             String     @id @default(cuid())
  userId         String
  shiftId        String?
  startDate      DateTime   @db.Date
  endDate        DateTime?  @db.Date
  workCycleId    String?
  cycleStartDate DateTime?  @db.Date // Ngày bắt đầu tính chu kỳ
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift          Shift?     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  workCycle      WorkCycle? @relation(fields: [workCycleId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@map("shift_assignments")
}

model Attendance {
  id               String                 @id @default(cuid())
  userId           String
  date             DateTime               @db.Date
  shiftId          String?
  checkIn          DateTime?
  checkOut         DateTime?
  checkInMethod    String? // MANUAL, QR, FACE_ID, GPS, WIFI, VANTAY
  checkOutMethod   String?
  checkInLocation  String? // Tọa độ GPS "lat,lng" hoặc tên WiFi
  checkOutLocation String?
  checkInPhoto     String? // URL ảnh selfie check-in
  checkOutPhoto    String? // URL ảnh selfie check-out
  checkInDeviceId  String? // ID máy chấm công
  checkOutDeviceId String?
  checkInVerified  Boolean                @default(false) // Đã xác minh chống gian lận
  checkOutVerified Boolean                @default(false)
  workHours        Float?
  overtimeHours    Float?
  lateMinutes      Int                    @default(0) // Số phút đi muộn
  earlyMinutes     Int                    @default(0) // Số phút về sớm
  status           String                 @default("PRESENT") // PRESENT, ABSENT, LATE, EARLY_LEAVE, HALF_DAY, LATE_AND_EARLY, ON_LEAVE, HOLIDAY
  note             String?
  isLocked         Boolean                @default(false)
  source           String                 @default("MANUAL") // MANUAL, WEB, DEVICE, API
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift            Shift?                 @relation(fields: [shiftId], references: [id])
  explanation      AttendanceExplanation?

  @@unique([userId, date])
  @@map("attendances")
}

model AttendanceExplanation {
  id             String     @id @default(cuid())
  attendanceId   String     @unique
  type           String     @default("OTHER") // LATE, EARLY_LEAVE, ABSENT, FORGOT_CHECKOUT, OTHER
  reason         String
  status         String     @default("PENDING") // PENDING, APPROVED, REJECTED
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  attachment     String? // URL đính kèm minh chứng
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  attendance     Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@map("attendance_explanations")
}

model OvertimeRequest {
  id          String   @id @default(cuid())
  userId      String // Nhân viên làm OT
  requestedBy String // Người tạo đơn (NV tự tạo hoặc Quản lý tạo hộ)
  date        DateTime @db.Date
  startTime   String
  endTime     String
  hours       Float // Số giờ đăng ký
  reason      String

  // Trạng thái luồng: PENDING → MANAGER_APPROVED → HR_APPROVED → COMPLETED
  // Hoặc: REJECTED, CANCELLED tại bất kỳ bước nào
  status String @default("PENDING")

  // Bước 2: Quản lý trực tiếp duyệt
  managerApprovedBy String?
  managerApprovedAt DateTime?
  managerNote       String?

  // Bước 3: HR kiểm soát
  hrApprovedBy String?
  hrApprovedAt DateTime?
  hrNote       String?

  // Từ chối (tại bước nào)
  rejectedBy     String?
  rejectedAt     DateTime?
  rejectedReason String?
  rejectedStep   String? // MANAGER, HR

  // Bước 4: Xác nhận kết quả thực tế
  actualStartTime String?
  actualEndTime   String?
  actualHours     Float?
  confirmedAt     DateTime?

  coefficient Float  @default(1.5) // Hệ số OT: 1.5x, 2x, 3x
  dayType     String @default("WEEKDAY") // WEEKDAY, WEEKEND, HOLIDAY

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("overtime_requests")
}

// ─── ANTI-FRAUD & DEVICE CONFIG ───

model AttendanceConfig {
  id                   String          @id @default(cuid())
  requireGps           Boolean         @default(true)
  requireWifi          Boolean         @default(false)
  requireSelfie        Boolean         @default(false)
  maxGpsDistanceMeters Int             @default(200) // Bán kính GPS cho phép (m)
  earlyCheckinMinutes  Int             @default(60) // Cho phép check-in sớm tối đa (phút) trước ca
  officeLat            Float? // Tọa độ văn phòng
  officeLng            Float?
  standardWorkHours    Float           @default(8) // Giờ làm chuẩn/ngày
  standardWorkDays     Int             @default(22) // Ngày công chuẩn/tháng
  otWeekdayCoeff       Float           @default(1.5) // Hệ số OT ngày thường
  otWeekendCoeff       Float           @default(2.0) // Hệ số OT cuối tuần
  otHolidayCoeff       Float           @default(3.0) // Hệ số OT ngày lễ
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  wifiWhitelist        WifiWhitelist[]

  @@map("attendance_configs")
}

model WifiWhitelist {
  id       String           @id @default(cuid())
  configId String
  ssid     String // Tên WiFi
  bssid    String? // MAC address WiFi
  config   AttendanceConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("wifi_whitelists")
}

model TimekeeperDevice {
  id        String    @id @default(cuid())
  name      String // "Máy chấm công Tầng 1"
  code      String    @unique
  type      String    @default("FINGERPRINT") // FINGERPRINT, FACE_ID, CARD, QR
  location  String? // "Cửa chính tầng 1"
  ipAddress String?
  apiKey    String? // Secret key cho xác thực webhook
  isActive  Boolean   @default(true)
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("timekeeper_devices")
}

model Holiday {
  id          String    @id @default(cuid())
  name        String // "Tết Nguyên đán", "Quốc khánh"
  date        DateTime  @db.Date
  endDate     DateTime? @db.Date // Nghỉ nhiều ngày
  isRecurring Boolean   @default(false) // Lặp lại hàng năm
  year        Int?
  createdAt   DateTime  @default(now())

  @@map("holidays")
}

// ─── WORK CYCLE (Chu kỳ làm việc linh động) ───

model WorkCycle {
  id               String            @id @default(cuid())
  name             String // "4 làm - 2 nghỉ", "Xoay ca 3 tuần"
  description      String?
  totalDays        Int // Tổng số ngày trong 1 chu kỳ
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  entries          WorkCycleEntry[]
  shiftAssignments ShiftAssignment[]

  @@map("work_cycles")
}

model WorkCycleEntry {
  id          String    @id @default(cuid())
  workCycleId String
  dayIndex    Int // 0-based: ngày thứ mấy trong chu kỳ
  shiftId     String? // null = ngày nghỉ
  isDayOff    Boolean   @default(false) // true = ngày nghỉ
  workCycle   WorkCycle @relation(fields: [workCycleId], references: [id], onDelete: Cascade)
  shift       Shift?    @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@unique([workCycleId, dayIndex])
  @@map("work_cycle_entries")
}

model AttendanceSummary {
  id              String    @id @default(cuid())
  userId          String
  month           Int
  year            Int
  totalWorkDays   Float     @default(0) // Ngày công thực tế
  standardDays    Float     @default(22) // Ngày công chuẩn
  lateDays        Int       @default(0) // Số ngày đi muộn
  earlyLeaveDays  Int       @default(0) // Số ngày về sớm
  absentDays      Float     @default(0) // Số ngày vắng
  leaveDays       Float     @default(0) // Nghỉ phép (được lương)
  unpaidLeaveDays Float     @default(0) // Nghỉ không lương
  holidayDays     Float     @default(0) // Ngày lễ
  otHoursWeekday  Float     @default(0) // Giờ OT ngày thường
  otHoursWeekend  Float     @default(0) // Giờ OT cuối tuần
  otHoursHoliday  Float     @default(0) // Giờ OT ngày lễ
  totalOtHours    Float     @default(0) // Tổng giờ OT
  totalWorkHours  Float     @default(0) // Tổng giờ làm
  isLocked        Boolean   @default(false)
  lockedBy        String?
  lockedAt        DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, month, year])
  @@map("attendance_summaries")
}

// ─── SETTINGS & AUDIT ───

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String   @default("")
  action    String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, EXPORT
  entity    String // User, Department, Shift, Attendance, ...
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
  group String? // general, attendance, payroll, leave

  @@map("system_settings")
}

// ─── RECRUITMENT MODULE ───

model JobPosting {
  id             String       @id @default(cuid())
  title          String
  departmentId   String?
  positionId     String?
  description    String       @db.Text
  requirements   String       @db.Text
  salaryMin      Decimal?     @db.Decimal(15, 0)
  salaryMax      Decimal?     @db.Decimal(15, 0)
  salaryCurrency String       @default("VND")
  headcount      Int          @default(1)
  employmentType String       @default("FULL_TIME") // FULL_TIME, PART_TIME, INTERN, CONTRACT
  status         String       @default("DRAFT") // DRAFT, OPEN, ON_HOLD, CLOSED
  priority       String       @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  deadline       DateTime?
  benefits       String?      @db.Text // Phúc lợi
  workLocation   String?      // Địa điểm làm việc
  interviewRounds Int         @default(1) // Số vòng phỏng vấn
  createdBy      String
  reviewedBy     String?
  reviewedAt     DateTime?
  closedBy       String?
  closedAt       DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  department     Department?   @relation(fields: [departmentId], references: [id])
  position       Position?     @relation(fields: [positionId], references: [id])
  candidates     Candidate[]
  interviews     Interview[]

  @@map("job_postings")
}

model Candidate {
  id           String       @id @default(cuid())
  jobPostingId String
  name         String
  email        String
  phone        String?
  gender       String?      // MALE, FEMALE, OTHER
  dateOfBirth  DateTime?
  address      String?
  cvUrl        String?      // URL CV file
  cvFileName   String?      // Tên file CV gốc
  linkedinUrl  String?
  portfolioUrl String?
  source       String       @default("WEBSITE") // WEBSITE, LINKEDIN, FACEBOOK, REFERRAL, AGENCY, OTHER
  sourceDetail String?      // Nguồn chi tiết
  stage        String       @default("APPLIED") // APPLIED, SCREENING, INTERVIEW, OFFER, HIRED, REJECTED
  rating       Int?         @default(0) // 1-5 sao
  rejectionReason String?
  hiredSalary  Decimal?     @db.Decimal(15, 0)
  hiredDate    DateTime?
  notes        String?      @db.Text
  tags         String[]     // Tags cho candidate pool
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  jobPosting   JobPosting   @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  interviews   Interview[]
  candidateTags CandidateTag[]

  @@unique([email, jobPostingId])
  @@map("candidates")
}

model CandidateTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1") // Màu tag
  createdAt DateTime @default(now())

  candidates Candidate[]

  @@map("candidate_tags")
}

model Interview {
  id            String    @id @default(cuid())
  candidateId   String
  jobPostingId  String
  round         Int       @default(1) // Vòng phỏng vấn
  type          String    @default("ONSITE") // ONSITE, ONLINE, PHONE
  method        String    @default("INDIVIDUAL") // INDIVIDUAL, GROUP, PANEL

  // Lịch phỏng vấn
  scheduledDate DateTime
  scheduledTime String    // "14:00"
  endTime       String?   // "15:00"
  duration      Int       @default(60) // Phút

  // Địa điểm/Link
  location      String?   // Địa điểi ONSITE
  meetingLink   String?   // Link meeting ONLINE
  meetingId     String?   // Zoom/Google Meet ID

  // Người phỏng vấn
  interviewerIds String[]  // Array of user IDs
  interviewerNames String[] // Array of interviewer names (cached)

  // Kết quả
  status        String    @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED, NO_SHOW
  result        String?   // PASS, FAIL, PENDING
  score         Int?      // Điểm tổng hợp 1-10
  strengths     String?   @db.Text
  weaknesses    String?   @db.Text
  notes         String?   @db.Text

  // Google Calendar integration
  googleEventId String?   // Google Calendar event ID
  calendarSync  Boolean   @default(false)

  // Thông tin phụ
  reviewedBy    String?
  reviewedAt    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobPosting    JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  feedbacks     InterviewFeedback[]

  @@map("interviews")
}

model InterviewFeedback {
  id           String   @id @default(cuid())
  interviewId  String
  userId       String   // Người phỏng vấn
  userName     String   // Tên người phỏng vấn (cached)

  // Đánh giá
  score        Int?     // Điểm 1-10
  result       String?  // PASS, FAIL, PENDING

  // Chi tiết
  technicalSkill Int?   // Kỹ thuật 1-5
  communication  Int?   // Giao tiếp 1-5
  problemSolving  Int?   // Giải quyết vấn đề 1-5
  cultureFit     Int?    // Văn hóa 1-5

  strengths    String?  @db.Text
  improvements String?  @db.Text
  notes        String?  @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  interview    Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, userId])
  @@map("interview_feedbacks")
}

// ─── ASSET MODULE ───

model Asset {
  id            String            @id @default(cuid())
  name          String
  code          String            @unique
  category      String            // LAPTOP, PHONE, MONITOR, DESK, CHAIR, CARD, OTHER
  status        String            @default("AVAILABLE") // AVAILABLE, ASSIGNED, MAINTENANCE, DISPOSED
  brand         String?
  model         String?
  serialNumber  String?
  purchaseDate  DateTime?
  purchasePrice Decimal?          @db.Decimal(15, 0)
  warrantyEnd   DateTime?
  location      String?
  description   String?
  createdBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  assignments   AssetAssignment[]

  @@index([category])
  @@index([status])
  @@map("assets")
}

model AssetAssignment {
  id             String    @id @default(cuid())
  assetId        String
  userId         String
  assignedBy     String?
  assignDate     DateTime  @default(now())
  expectedReturn DateTime?
  returnDate     DateTime?
  returnedTo     String?
  status         String    @default("ASSIGNED") // ASSIGNED, RETURNED
  condition      String?   // GOOD, DAMAGED, LOST
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@map("asset_assignments")
}

// ─── OFFBOARDING MODULE ───

model OffboardingTemplate {
  id          String              @id @default(cuid())
  name        String
  description String?
  tasks       OffboardingTask[]
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  offboardings Offboarding[]

  @@map("offboarding_templates")
}

model OffboardingTask {
  id           String              @id @default(cuid())
  templateId   String
  title        String
  description  String?
  category     String              @default("GENERAL") // GENERAL, ASSET, ACCOUNT, FINANCIAL, INTERVIEW
  assigneeRole String?             // Role phụ trách: HR_STAFF, IT_ADMIN, DEPT_MANAGER, ACCOUNTANT
  dueDays      Int                 @default(7) // Số ngày trước khi nghỉ việc
  sortOrder    Int                 @default(0)
  isRequired   Boolean             @default(true)
  template     OffboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("offboarding_tasks")
}

model Offboarding {
  id             String                @id @default(cuid())
  userId         String
  templateId     String?
  resignDate     DateTime              @db.Date // Ngày nộp đơn nghỉ
  lastWorkDate   DateTime              @db.Date // Ngày làm việc cuối cùng
  reason         String?               // Lý do nghỉ việc
  reasonDetail   String?              @db.Text // Chi tiết lý do
  status         String                @default("PROCESSING") // PROCESSING, COMPLETED, CANCELLED
  exitInterview  String?               @db.Text // Nội dung exit interview
  interviewDate DateTime?
  interviewerId  String?
  
  // Tài chính
  finalSalary           Decimal?       @db.Decimal(15, 0) // Lương cuối cùng
  unusedLeaveDays       Float?         @default(0) // Ngày phép chưa dùng
  unusedLeaveAmount    Decimal?       @db.Decimal(15, 0) // Tiền phép chưa dùng
  severancePay         Decimal?       @db.Decimal(15, 0) // Trợ cấp thôi việc
  otherAllowances      Decimal?       @db.Decimal(15, 0) // Các khoản khác
  totalFinalPayment    Decimal?       @db.Decimal(15, 0) // Tổng thanh toán
  
  // Thông tin tạo/cập nhật
  createdBy      String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  completedAt    DateTime?

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template       OffboardingTemplate? @relation(fields: [templateId], references: [id])
  checklist      OffboardingChecklist[]
  assets         OffboardingAsset[]

  @@index([userId])
  @@index([status])
  @@map("offboardings")
}

model OffboardingChecklist {
  id              String      @id @default(cuid())
  offboardingId   String
  taskTitle       String
  taskDescription String?
  category        String      @default("GENERAL")
  assigneeRole    String?
  assigneeId      String?     // User ID được giao
  isCompleted     Boolean     @default(false)
  completedBy     String?
  completedAt     DateTime?
  dueDate         DateTime?
  notes           String?
  offboarding     Offboarding @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([offboardingId])
  @@map("offboarding_checklists")
}

model OffboardingAsset {
  id              String      @id @default(cuid())
  offboardingId   String
  assetId         String?
  assetName       String      // Tên tài sản (cached)
  assetCode       String?     // Mã tài sản (cached)
  category        String?     // Loại tài sản
  status          String      @default("PENDING") // PENDING, RETURNED, DAMAGED, NOT_RETURNED
  returnDate      DateTime?
  returnedTo      String?
  condition       String?     // Tình trạng khi trả: GOOD, DAMAGED
  notes           String?
  offboarding     Offboarding @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([offboardingId])
  @@map("offboarding_assets")
}
