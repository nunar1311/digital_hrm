  departmentName  String?
  position        String?
  baseSalary      Decimal       @db.Decimal(15, 0)
  grossSalary     Decimal       @db.Decimal(15, 0)
  netSalary       Decimal       @db.Decimal(15, 0)
  earnings        Json          @default("[]")
  deductions      Json          @default("[]")
  insurance       Json          @default("{}")
  tax             Json          @default("{}")
  status          String        @default("GENERATED")
  isSecure        Boolean       @default(true) // Yêu cầu mật khẩu để xem
