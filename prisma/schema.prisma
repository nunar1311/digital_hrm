generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                    @id @default(cuid())
  name                     String
  email                    String                    @unique
  emailVerified            Boolean                   @default(false)
  image                    String?
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  employeeCode             String?                   @unique
  departmentId             String?
  departmentRole           String?                   @default("MEMBER")
  hrmRole                  String                    @default("EMPLOYEE")
  address                  String?
  avatar                   String?
  bankAccount              String?
  bankBranch               String?
  bankName                 String?
  dateOfBirth              DateTime?
  educationLevel           String?
  employeeStatus           String?                   @default("ACTIVE")
  employmentType           String?                   @default("FULL_TIME")
  ethnicity                String?                   @default("Kinh")
  fullName                 String?
  gender                   String?
  healthInsuranceNo        String?
  hireDate                 DateTime?
  positionId               String?
  major                    String?
  managerId                String?
  maritalStatus            String?
  nationalId               String?
  nationalIdDate           DateTime?
  nationalIdPlace          String?
  nationality              String?                   @default("Việt Nam")
  notes                    String?
  permanentAddress         String?
  personalEmail            String?
  phone                    String?
  probationEnd             DateTime?
  religion                 String?
  resignDate               DateTime?
  socialInsuranceNo        String?
  taxCode                  String?
  university               String?
  accounts                 Account[]
  attendanceSummaries      AttendanceSummary[]
  attendances              Attendance[]
  managedDepartments       Department[]              @relation("DeptManager")
  employeeSalaryComponents EmployeeSalaryComponent[]
  members                  Member[]
  offboardings             Offboarding[]
  overtimeRequests         OvertimeRequest[]
  payrollRecordDetails     PayrollRecordDetail[]
  payslips                 Payslip[]
  salaries                 Salary?
  sessions                 Session[]
  shiftAssignments         ShiftAssignment[]
  department               Department?               @relation(fields: [departmentId], references: [id])
  manager                  User?                     @relation("ManagerReports", fields: [managerId], references: [id])
  reports                  User[]                    @relation("ManagerReports")
  notifications            Notification[]
  notificationPreference   NotificationPreference?   @relation(fields: [notificationPreferenceId], references: [id])
  notificationPreferenceId String?
  emailLogs                EmailLog[]
  position                 Position?                @relation(fields: [positionId], references: [id])
  profileUpdateRequests    ProfileUpdateRequest[]
  administrativeRequests   AdministrativeRequest[]

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verifications")
}

model Organization {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  logo              String?
  metadata          String?
  email             String? // Email công ty
  country           String? // Quốc gia
  agreementAccepted Boolean   @default(false) // Đã đồng ý điều khoản
  agreementDate     DateTime? // Ngày đồng ý điều khoản
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  members           Member[]

  @@map("organizations")
}

model Member {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("members")
}

model Department {
  id                 String          @id @default(cuid())
  name               String
  code               String          @unique
  logo               String?
  description        String?
  parentId           String?
  secondaryParentIds String[]
  managerId          String?
  status             String          @default("ACTIVE")
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  manager            User?           @relation("DeptManager", fields: [managerId], references: [id])
  parent             Department?     @relation("DeptHierarchy", fields: [parentId], references: [id])
  children           Department[]    @relation("DeptHierarchy")
  jobPostings        JobPosting[]
  positions          Position[]
  users              User[]
  payroll_records    PayrollRecord[] @relation("DepartmentToPayrollRecord")
  payrollRecord      PayrollRecord?  @relation("PayrollRecordDepartment")

  @@map("departments")
}

model Position {
  id           String       @id @default(cuid())
  name         String
  code         String       @unique
  authority    String       @default("STAFF") // EXECUTIVE, DIRECTOR, MANAGER, DEPUTY, TEAM_LEAD, STAFF, INTERN
  departmentId String?
  level        Int          @default(1) // 1=cao nhất (Giám đốc), 7=thấp nhất (Thực tập)
  description  String?
  parentId     String?
  minSalary    Decimal?     @db.Decimal(15, 0)
  maxSalary    Decimal?     @db.Decimal(15, 0)
  status       String       @default("ACTIVE") // ACTIVE, INACTIVE
  sortOrder    Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @default(now()) @updatedAt
  jobPostings  JobPosting[]
  department   Department?  @relation(fields: [departmentId], references: [id])
  users        User[]
  parent       Position?    @relation("PositionHierarchy", fields: [parentId], references: [id])
  children     Position[]   @relation("PositionHierarchy")

  @@map("positions")
}

model Shift {
  id               String            @id @default(cuid())
  name             String
  code             String            @unique
  startTime        String
  endTime          String
  breakMinutes     Int               @default(60)
  lateThreshold    Int               @default(15)
  earlyThreshold   Int               @default(15)
  isDefault        Boolean           @default(false)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  attendances      Attendance[]
  shiftAssignments ShiftAssignment[]
  workCycleEntries WorkCycleEntry[]

  @@map("shifts")
}

model ShiftAssignment {
  id             String     @id @default(cuid())
  userId         String
  shiftId        String?
  startDate      DateTime   @db.Date
  endDate        DateTime?  @db.Date
  workCycleId    String?
  cycleStartDate DateTime?  @db.Date
  createdAt      DateTime   @default(now())
  shift          Shift?     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workCycle      WorkCycle? @relation(fields: [workCycleId], references: [id], onDelete: Cascade)

  @@map("shift_assignments")
}

model Attendance {
  id               String                 @id @default(cuid())
  userId           String
  date             DateTime               @db.Date
  shiftId          String?
  checkIn          DateTime?
  checkOut         DateTime?
  checkInMethod    String?
  checkOutMethod   String?
  checkInLocation  String?
  checkOutLocation String?
  checkInPhoto     String?
  checkOutPhoto    String?
  checkInDeviceId  String?
  checkOutDeviceId String?
  checkInVerified  Boolean                @default(false)
  checkOutVerified Boolean                @default(false)
  workHours        Float?
  overtimeHours    Float?
  lateMinutes      Int                    @default(0)
  earlyMinutes     Int                    @default(0)
  status           String                 @default("PRESENT")
  note             String?
  isLocked         Boolean                @default(false)
  source           String                 @default("MANUAL")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  explanation      AttendanceExplanation?
  shift            Shift?                 @relation(fields: [shiftId], references: [id])
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendances")
}

model AttendanceExplanation {
  id             String     @id @default(cuid())
  attendanceId   String     @unique
  type           String     @default("OTHER")
  reason         String
  status         String     @default("PENDING")
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  attachment     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  attendance     Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@map("attendance_explanations")
}

model OvertimeRequest {
  id                String    @id @default(cuid())
  userId            String
  requestedBy       String
  date              DateTime  @db.Date
  startTime         String
  endTime           String
  hours             Float
  reason            String
  status            String    @default("PENDING")
  managerApprovedBy String?
  managerApprovedAt DateTime?
  managerNote       String?
  hrApprovedBy      String?
  hrApprovedAt      DateTime?
  hrNote            String?
  rejectedBy        String?
  rejectedAt        DateTime?
  rejectedReason    String?
  rejectedStep      String?
  actualStartTime   String?
  actualEndTime     String?
  actualHours       Float?
  confirmedAt       DateTime?
  coefficient       Float     @default(1.5)
  dayType           String    @default("WEEKDAY")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("overtime_requests")
}

model AttendanceConfig {
  id                   String          @id @default(cuid())
  requireGps           Boolean         @default(true)
  requireWifi          Boolean         @default(false)
  requireSelfie        Boolean         @default(false)
  maxGpsDistanceMeters Int             @default(200)
  earlyCheckinMinutes  Int             @default(60)
  officeLat            Float?
  officeLng            Float?
  standardWorkHours    Float           @default(8)
  standardWorkDays     Int             @default(22)
  otWeekdayCoeff       Float           @default(1.5)
  otWeekendCoeff       Float           @default(2.0)
  otHolidayCoeff       Float           @default(3.0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  wifiWhitelist        WifiWhitelist[]

  @@map("attendance_configs")
}

model WifiWhitelist {
  id       String           @id @default(cuid())
  configId String
  ssid     String
  bssid    String?
  config   AttendanceConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("wifi_whitelists")
}

model TimekeeperDevice {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  type      String    @default("FINGERPRINT")
  location  String?
  ipAddress String?
  apiKey    String?
  isActive  Boolean   @default(true)
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("timekeeper_devices")
}

model Holiday {
  id          String    @id @default(cuid())
  name        String
  date        DateTime  @db.Date
  endDate     DateTime? @db.Date
  isRecurring Boolean   @default(false)
  year        Int?
  createdAt   DateTime  @default(now())

  @@map("holidays")
}

model WorkCycle {
  id               String            @id @default(cuid())
  name             String
  description      String?
  totalDays        Int
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  shiftAssignments ShiftAssignment[]
  entries          WorkCycleEntry[]

  @@map("work_cycles")
}

model WorkCycleEntry {
  id          String    @id @default(cuid())
  workCycleId String
  dayIndex    Int
  shiftId     String?
  isDayOff    Boolean   @default(false)
  shift       Shift?    @relation(fields: [shiftId], references: [id])
  workCycle   WorkCycle @relation(fields: [workCycleId], references: [id], onDelete: Cascade)

  @@unique([workCycleId, dayIndex])
  @@map("work_cycle_entries")
}

model AttendanceSummary {
  id              String    @id @default(cuid())
  userId          String
  month           Int
  year            Int
  totalWorkDays   Float     @default(0)
  standardDays    Float     @default(22)
  lateDays        Int       @default(0)
  earlyLeaveDays  Int       @default(0)
  absentDays      Float     @default(0)
  leaveDays       Float     @default(0)
  unpaidLeaveDays Float     @default(0)
  holidayDays     Float     @default(0)
  otHoursWeekday  Float     @default(0)
  otHoursWeekend  Float     @default(0)
  otHoursHoliday  Float     @default(0)
  totalOtHours    Float     @default(0)
  totalWorkHours  Float     @default(0)
  isLocked        Boolean   @default(false)
  lockedBy        String?
  lockedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("attendance_summaries")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String   @default("")
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
  group String?

  @@map("system_settings")
}

model JobPosting {
  id              String      @id @default(cuid())
  title           String
  departmentId    String?
  positionId      String?
  description     String
  requirements    String
  salaryMin       Decimal?    @db.Decimal(15, 0)
  salaryMax       Decimal?    @db.Decimal(15, 0)
  salaryCurrency  String      @default("VND")
  headcount       Int         @default(1)
  employmentType  String      @default("FULL_TIME")
  status          String      @default("DRAFT")
  priority        String      @default("NORMAL")
  deadline        DateTime?
  benefits        String?
  workLocation    String?
  interviewRounds Int         @default(1)
  createdBy       String
  reviewedBy      String?
  reviewedAt      DateTime?
  closedBy        String?
  closedAt        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  candidates      Candidate[]
  interviews      Interview[]
  department      Department? @relation(fields: [departmentId], references: [id])
  position        Position?   @relation(fields: [positionId], references: [id])

  @@map("job_postings")
}

model Candidate {
  id                      String                    @id @default(cuid())
  jobPostingId            String
  name                    String
  email                   String
  phone                   String?
  gender                  String?
  dateOfBirth             DateTime?
  address                 String?
  cvUrl                   String?
  cvFileName              String?
  linkedinUrl             String?
  portfolioUrl            String?
  source                  String                    @default("WEBSITE")
  sourceDetail            String?
  stage                   String                    @default("APPLIED")
  rating                  Int?                      @default(0)
  rejectionReason         String?
  hiredSalary             Decimal?                  @db.Decimal(15, 0)
  hiredDate               DateTime?
  notes                   String?
  tags                    String[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  CandidateToCandidateTag CandidateToCandidateTag[]
  jobPosting              JobPosting                @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  interviews              Interview[]

  @@unique([email, jobPostingId])
  @@map("candidates")
}

model CandidateTag {
  id                      String                    @id @default(cuid())
  name                    String                    @unique
  color                   String                    @default("#6366f1")
  createdAt               DateTime                  @default(now())
  CandidateToCandidateTag CandidateToCandidateTag[]

  @@map("candidate_tags")
}

model Interview {
  id               String              @id @default(cuid())
  candidateId      String
  jobPostingId     String
  round            Int                 @default(1)
  type             String              @default("ONSITE")
  method           String              @default("INDIVIDUAL")
  scheduledDate    DateTime
  scheduledTime    String
  endTime          String?
  duration         Int                 @default(60)
  location         String?
  meetingLink      String?
  meetingId        String?
  interviewerIds   String[]
  interviewerNames String[]
  status           String              @default("SCHEDULED")
  result           String?
  score            Int?
  strengths        String?
  weaknesses       String?
  notes            String?
  googleEventId    String?
  calendarSync     Boolean             @default(false)
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  feedbacks        InterviewFeedback[]
  candidate        Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobPosting       JobPosting          @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

model InterviewFeedback {
  id             String    @id @default(cuid())
  interviewId    String
  userId         String
  userName       String
  score          Int?
  result         String?
  technicalSkill Int?
  communication  Int?
  problemSolving Int?
  cultureFit     Int?
  strengths      String?
  improvements   String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, userId])
  @@map("interview_feedbacks")
}

model Asset {
  id            String            @id @default(cuid())
  name          String
  code          String            @unique
  category      String
  status        String            @default("AVAILABLE")
  brand         String?
  model         String?
  serialNumber  String?
  purchaseDate  DateTime?
  purchasePrice Decimal?          @db.Decimal(15, 0)
  warrantyEnd   DateTime?
  location      String?
  description   String?
  createdBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  assignments   AssetAssignment[]

  @@index([category])
  @@index([status])
  @@map("assets")
}

model AssetAssignment {
  id             String    @id @default(cuid())
  assetId        String
  userId         String
  assignedBy     String?
  assignDate     DateTime  @default(now())
  expectedReturn DateTime?
  returnDate     DateTime?
  returnedTo     String?
  status         String    @default("ASSIGNED")
  condition      String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@map("asset_assignments")
}

model OffboardingTemplate {
  id           String            @id @default(cuid())
  name         String
  description  String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tasks        OffboardingTask[]
  offboardings Offboarding[]

  @@map("offboarding_templates")
}

model OffboardingTask {
  id           String              @id @default(cuid())
  templateId   String
  title        String
  description  String?
  category     String              @default("GENERAL")
  assigneeRole String?
  dueDays      Int                 @default(7)
  sortOrder    Int                 @default(0)
  isRequired   Boolean             @default(true)
  template     OffboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("offboarding_tasks")
}

model Offboarding {
  id                String                 @id @default(cuid())
  userId            String
  templateId        String?
  resignDate        DateTime               @db.Date
  lastWorkDate      DateTime               @db.Date
  reason            String?
  reasonDetail      String?
  status            String                 @default("PROCESSING")
  exitInterview     String?
  interviewDate     DateTime?
  interviewerId     String?
  finalSalary       Decimal?               @db.Decimal(15, 0)
  unusedLeaveDays   Float?                 @default(0)
  unusedLeaveAmount Decimal?               @db.Decimal(15, 0)
  severancePay      Decimal?               @db.Decimal(15, 0)
  otherAllowances   Decimal?               @db.Decimal(15, 0)
  totalFinalPayment Decimal?               @db.Decimal(15, 0)
  createdBy         String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  completedAt       DateTime?
  assets            OffboardingAsset[]
  checklist         OffboardingChecklist[]
  template          OffboardingTemplate?   @relation(fields: [templateId], references: [id])
  user              User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("offboardings")
}

model OffboardingChecklist {
  id              String      @id @default(cuid())
  offboardingId   String
  taskTitle       String
  taskDescription String?
  category        String      @default("GENERAL")
  assigneeRole    String?
  assigneeId      String?
  isCompleted     Boolean     @default(false)
  completedBy     String?
  completedAt     DateTime?
  dueDate         DateTime?
  notes           String?
  offboarding     Offboarding @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([offboardingId])
  @@map("offboarding_checklists")
}

model OffboardingAsset {
  id            String      @id @default(cuid())
  offboardingId String
  assetId       String?
  assetName     String
  assetCode     String?
  category      String?
  status        String      @default("PENDING")
  returnDate    DateTime?
  returnedTo    String?
  condition     String?
  notes         String?
  offboarding   Offboarding @relation(fields: [offboardingId], references: [id], onDelete: Cascade)

  @@index([offboardingId])
  @@map("offboarding_assets")
}

model Salary {
  id            String   @id @default(cuid())
  userId        String   @unique
  baseSalary    Decimal  @db.Decimal(15, 0)
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("salaries")
}

model SalaryComponentType {
  id                 String                    @id @default(cuid())
  code               String                    @unique
  name               String
  description        String?
  category           String
  isTaxable          Boolean                   @default(true)
  isInsurance        Boolean                   @default(false)
  isBase             Boolean                   @default(false)
  coefficient        Decimal?                  @db.Decimal(5, 2)
  maxAmount          Decimal?                  @db.Decimal(15, 0)
  isActive           Boolean                   @default(true)
  sortOrder          Int                       @default(0)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  employeeComponents EmployeeSalaryComponent[]
  payrollDetails     PayrollRecordDetail[]

  @@map("salary_component_types")
}

model EmployeeSalaryComponent {
  id              String              @id @default(cuid())
  userId          String
  componentTypeId String
  amount          Decimal             @db.Decimal(15, 0)
  effectiveDate   DateTime            @default(now())
  endDate         DateTime?           @db.Date
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  componentType   SalaryComponentType @relation(fields: [componentTypeId], references: [id])
  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, componentTypeId, effectiveDate])
  @@map("employee_salary_components")
}

model PayrollRecord {
  id              String                @id @default(cuid())
  month           Int
  year            Int
  departmentId    String?               @unique
  status          String                @default("DRAFT")
  totalEmployees  Int                   @default(0)
  totalGross      Decimal               @default(0) @db.Decimal(18, 0)
  totalNet        Decimal               @default(0) @db.Decimal(18, 0)
  totalTax        Decimal               @default(0) @db.Decimal(18, 0)
  totalInsurance  Decimal               @default(0) @db.Decimal(18, 0)
  totalDeductions Decimal               @default(0) @db.Decimal(18, 0)
  processedBy     String?
  processedAt     DateTime?
  approvedBy      String?
  approvedAt      DateTime?
  note            String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  details         PayrollRecordDetail[]
  payslips        Payslip[]
  departments     Department[]          @relation("DepartmentToPayrollRecord")
  department      Department?           @relation("PayrollRecordDepartment", fields: [departmentId], references: [id])

  @@unique([month, year, departmentId])
  @@index([status])
  @@index([month, year])
  @@map("payroll_records")
}

model PayrollRecordDetail {
  id                    String               @id @default(cuid())
  payrollRecordId       String
  userId                String
  baseSalary            Decimal              @db.Decimal(15, 0)
  grossSalary           Decimal              @db.Decimal(15, 0)
  taxableIncome         Decimal              @db.Decimal(15, 0)
  netSalary             Decimal              @db.Decimal(15, 0)
  overtimeAmount        Decimal              @default(0) @db.Decimal(15, 0)
  allowanceAmount       Decimal              @default(0) @db.Decimal(15, 0)
  bonusAmount           Decimal              @default(0) @db.Decimal(15, 0)
  deductionAmount       Decimal              @default(0) @db.Decimal(15, 0)
  socialInsurance       Decimal              @default(0) @db.Decimal(15, 0)
  healthInsurance       Decimal              @default(0) @db.Decimal(15, 0)
  unemploymentInsurance Decimal              @default(0) @db.Decimal(15, 0)
  personalDeduction     Decimal              @default(11000000) @db.Decimal(15, 0)
  dependentDeduction    Decimal              @default(0) @db.Decimal(15, 0)
  taxAmount             Decimal              @default(0) @db.Decimal(15, 0)
  workDays              Float                @default(0)
  standardDays          Float                @default(22)
  lateDays              Int                  @default(0)
  overtimeHours         Float                @default(0)
  status                String               @default("PENDING")
  paidAt                DateTime?
  bankAccount           String?
  bankName              String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  componentTypeId       String?
  componentType         SalaryComponentType? @relation(fields: [componentTypeId], references: [id])
  payrollRecord         PayrollRecord        @relation(fields: [payrollRecordId], references: [id], onDelete: Cascade)
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([payrollRecordId, userId])
  @@index([userId])
  @@map("payroll_record_details")
}

model PayrollConfig {
  id            String   @id @default(cuid())
  key           String   @unique
  value         Decimal  @db.Decimal(10, 2)
  description   String?
  effectiveDate DateTime @default(now())
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("payroll_configs")
}

model Payslip {
  id              String        @id @default(cuid())
  userId          String
  payrollRecordId String
  month           Int
  year            Int
  employeeCode    String?
  employeeName    String
  departmentName  String?
  position        String?
  baseSalary      Decimal       @db.Decimal(15, 0)
  grossSalary     Decimal       @db.Decimal(15, 0)
  netSalary       Decimal       @db.Decimal(15, 0)
  earnings        Json          @default("[]")
  deductions      Json          @default("[]")
  insurance       Json          @default("{}")
  tax             Json          @default("{}")
  status          String        @default("GENERATED")
  isSecure        Boolean       @default(true)  // Yêu cầu mật khẩu để xem
  passwordHash    String?       // Mật khẩu băm ( bcrypt )
  viewedAt        DateTime?
  downloadedAt    DateTime?
  signedBy        String?
  signedAt        DateTime?
  sentEmailAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payrollRecord   PayrollRecord @relation(fields: [payrollRecordId], references: [id])
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
  @@index([month, year])
  @@index([payrollRecordId])
  @@map("payslips")
}

// ==================== DYNAMIC FORMULA SYSTEM ====================

model PayrollFormula {
  id            String                  @id @default(cuid())
  code          String                  @unique
  name          String
  description   String?
  formulaType   String                  @default("EARNING") // EARNING, DEDUCTION, TAX, INSURANCE, NET
  category      String?                 // ALLOWANCE, BONUS, OVERTIME, DISCIPLINE, etc.
  expression    String                  // Công thức Excel-like: baseSalary + allowance * coefficient
  variables     Json                    @default("[]") // [{name: "baseSalary", source: "SALARY"}, ...]
  outputField   String?                 // Trường xuất ra: overtimeAmount, allowanceAmount, etc.
  priority      Int                     @default(0) // Thứ tự tính toán
  isActive      Boolean                 @default(true)
  isSystem      Boolean                 @default(false) // Công thức hệ thống, không thể xóa
  effectiveDate DateTime                @default(now())
  createdBy     String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([formulaType])
  @@index([isActive])
  @@map("payroll_formulas")
}

model PayrollFormulaVariable {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  dataType    String   @default("NUMBER") // NUMBER, PERCENT, BOOLEAN, TEXT
  source      String   @default("CONFIG") // CONFIG, ATTENDANCE, SALARY, COMPONENT, TAX, INSURANCE, CONSTANT
  defaultValue Decimal? @db.Decimal(15, 0)
  minValue    Decimal? @db.Decimal(15, 0)
  maxValue    Decimal? @db.Decimal(15, 0)
  unit        String?  // VND, %, hours, days
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
  @@map("payroll_formula_variables")
}

model PayrollApproval {
  id              String        @id @default(cuid())
  payrollRecordId String
  action          String        // CREATED, SUBMITTED, APPROVED, REJECTED, PAID
  status          String        @default("PENDING") // PENDING, APPROVED, REJECTED
  note            String?
  approverId      String?
  approverName    String?
  approvedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([payrollRecordId])
  @@map("payroll_approvals")
}

// ==================== INSURANCE & TAX CAPS ====================

model InsuranceCap {
  id            String   @id @default(cuid())
  year          Int
  insuranceType String   // SOCIAL, HEALTH, UNEMPLOYMENT
  minSalary     Decimal  @db.Decimal(15, 0)
  maxSalary     Decimal  @db.Decimal(15, 0)
  region        String?  // Vùng lương tối thiểu theo vùng
  isActive      Boolean  @default(true)
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([year, insuranceType, region])
  @@index([year])
  @@map("insurance_caps")
}

// ==================== STANDARD WORK DAYS ====================

model StandardWorkDays {
  id       String   @id @default(cuid())
  year     Int
  month    Int
  workDays Float    @default(22) // Số ngày làm việc chuẩn tháng
  workHours Float   @default(176) // Số giờ làm việc chuẩn tháng (22 * 8)
  holidays Json     @default("[]") // Danh sách ngày nghỉ lễ trong tháng
  note     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month])
  @@index([year])
  @@map("standard_work_days")
}

model CandidateToCandidateTag {
  A              String
  B              String
  candidates     Candidate    @relation(fields: [A], references: [id], onDelete: Cascade)
  candidate_tags CandidateTag @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_CandidateToCandidateTag_AB_pkey")
  @@index([B], map: "_CandidateToCandidateTag_B_index")
  @@map("_CandidateToCandidateTag")
}

// ==================== NOTIFICATION SYSTEM ====================

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String // ATTENDANCE, LEAVE, PAYROLL, OVERTIME, SYSTEM, etc.
  title     String
  content   String
  link      String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  priority  String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  // Email channel
  emailEnabled             Boolean  @default(true)
  quietHoursEnabled        Boolean  @default(false)
  quietHoursStart          String? // "22:00"
  quietHoursEnd            String? // "08:00"
  notificationTypes        String[] @default([]) // Email notification types (legacy - keeping for backward compatibility)
  // Email channel - new separate fields (matching inbox pattern)
  emailNotificationTypes   String[] @default([])
  emailQuietHoursEnabled   Boolean  @default(false)
  emailQuietHoursStart     String?
  emailQuietHoursEnd       String?
  // Browser channel
  browserEnabled           Boolean  @default(true)
  browserSoundEnabled      Boolean  @default(true)
  browserNotificationTypes String[] @default([])
  browserQuietHoursEnabled Boolean  @default(false)
  browserQuietHoursStart   String?
  browserQuietHoursEnd     String?
  // Inbox channel (separate from email - using new fields)
  inboxNotificationTypes   String[] @default([])
  inboxQuietHoursEnabled   Boolean  @default(false)
  inboxQuietHoursStart     String? // "22:00"
  inboxQuietHoursEnd       String? // "08:00"
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  users                    User[]

  @@map("notification_preferences")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  code      String   @unique // ATTENDANCE_REMINDER, LEAVE_APPROVED, PAYSLIP_READY, etc.
  name      String
  subject   String
  body      String   @db.Text
  bodyHtml  String?  @db.Text
  isActive  Boolean  @default(true)
  variables Json     @default("[]") // ["{{employeeName}}", "{{date}}", etc.]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model EmailLog {
  id           String    @id @default(cuid())
  userId       String?
  recipient    String
  subject      String
  body         String?   @db.Text
  status       String    @default("PENDING") // PENDING, SENT, FAILED, BOUNCED
  errorMessage String?
  templateCode String?
  metadata     Json?
  sentAt       DateTime?
  createdAt    DateTime  @default(now())
  users        User[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

model ProfileUpdateRequest {
  id            String    @id @default(cuid())
  userId        String
  requestedData Json
  status        String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedBy    String?
  reviewedAt    DateTime?
  rejectReason  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("profile_update_requests")
}

model AdministrativeRequest {
  id                 String    @id @default(cuid())
  userId             String
  type               String
  description        String    @db.Text
  status             String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedBy         String?
  reviewedAt         DateTime?
  responseAttachment String?
  rejectReason       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("administrative_requests")
}
