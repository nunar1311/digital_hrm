// ==================== DYNAMIC FORMULA SYSTEM ====================

model PayrollFormula {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  formulaType   String   @default("EARNING") // EARNING, DEDUCTION, TAX, INSURANCE, NET
  category      String? // ALLOWANCE, BONUS, OVERTIME, DISCIPLINE, etc.
  expression    String // Công thức Excel-like: baseSalary + allowance * coefficient
  variables     Json     @default("[]") // [{name: "baseSalary", source: "SALARY"}, ...]
  outputField   String? // Trường xuất ra: overtimeAmount, allowanceAmount, etc.
  priority      Int      @default(0) // Thứ tự tính toán
  isActive      Boolean  @default(true)
  isSystem      Boolean  @default(false) // Công thức hệ thống, không thể xóa
  effectiveDate DateTime @default(now())
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([formulaType])
  @@index([isActive])
  @@map("payroll_formulas")
}

model PayrollFormulaVariable {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?
  dataType     String   @default("NUMBER") // NUMBER, PERCENT, BOOLEAN, TEXT
  source       String   @default("CONFIG") // CONFIG, ATTENDANCE, SALARY, COMPONENT, TAX, INSURANCE, CONSTANT
  defaultValue Decimal? @db.Decimal(15, 0)
  minValue     Decimal? @db.Decimal(15, 0)
  maxValue     Decimal? @db.Decimal(15, 0)
  unit         String? // VND, %, hours, days
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([source])
  @@map("payroll_formula_variables")
}

model PayrollApproval {
