  socialInsurance       Decimal              @default(0) @db.Decimal(15, 0)
  healthInsurance       Decimal              @default(0) @db.Decimal(15, 0)
  unemploymentInsurance Decimal              @default(0) @db.Decimal(15, 0)
  personalDeduction     Decimal              @default(11000000) @db.Decimal(15, 0)
