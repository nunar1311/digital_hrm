  totalNet        Decimal               @default(0) @db.Decimal(18, 0)
  totalTax        Decimal               @default(0) @db.Decimal(18, 0)
  totalInsurance  Decimal               @default(0) @db.Decimal(18, 0)
  totalDeductions Decimal               @default(0) @db.Decimal(18, 0)
