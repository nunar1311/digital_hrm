  status          String    @default("PENDING") // PENDING, APPROVED, REJECTED
  note            String?
  approverId      String?
  approverName    String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([payrollRecordId])
  @@map("payroll_approvals")
}

