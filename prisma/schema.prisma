generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                           String                        @id @default(cuid())
  name                         String
  email                        String                        @unique
  emailVerified                Boolean                       @default(false)
  image                        String?
  createdAt                    DateTime                      @default(now())
  updatedAt                    DateTime                      @updatedAt
  username                     String?                       @unique
  displayUsername              String?
  departmentId                 String?
  departmentRole               String?                       @default("MEMBER")
  hrmRole                      String                        @default("EMPLOYEE")
  payrollCompanyId             String?
  address                      String?
  avatar                       String?
  bankAccount                  String?
  bankBranch                   String?
  bankName                     String?
  dateOfBirth                  DateTime?
  educationLevel               String?
  employeeStatus               String?                       @default("ACTIVE")
  employmentType               String?                       @default("FULL_TIME")
  ethnicity                    String?                       @default("Kinh")
  fullName                     String?
  gender                       String?
  healthInsuranceNo            String?
  hireDate                     DateTime?
  positionId                   String?
  major                        String?
  managerId                    String?
  maritalStatus                String?
  nationalId                   String?
  nationalIdDate               DateTime?
  nationalIdPlace              String?
  nationality                  String?                       @default("Việt Nam")
  notes                        String?
  permanentAddress             String?
  personalEmail                String?
  phone                        String?
  probationEnd                 DateTime?
  religion                     String?
  resignDate                   DateTime?
  socialInsuranceNo            String?
  taxCode                      String?
  university                   String?
  accounts                     Account[]
  attendanceSummaries          AttendanceSummary[]
  attendances                  Attendance[]
  managedDepartments           Department[]                  @relation("DeptManager")
  employeeSalaryComponents     EmployeeSalaryComponent[]
  members                      Member[]
  offboardings                 Offboarding[]
  overtimeRequests             OvertimeRequest[]
  payrollRecordDetails         PayrollRecordDetail[]
  payslips                     Payslip[]
  salaries                     Salary?
  sessions                     Session[]
  shiftAssignments             ShiftAssignment[]
  department                   Department?                   @relation(fields: [departmentId], references: [id])
  manager                      User?                         @relation("ManagerReports", fields: [managerId], references: [id])
  reports                      User[]                        @relation("ManagerReports")
  notifications                Notification[]
  notificationPreference       NotificationPreference?       @relation(fields: [notificationPreferenceId], references: [id])
  notificationPreferenceId     String?
  emailLogs                    EmailLog[]
  position                     Position?                     @relation(fields: [positionId], references: [id])
  profileUpdateRequests        ProfileUpdateRequest[]
  administrativeRequests       AdministrativeRequest[]
  attendanceAdjustmentRequests AttendanceAdjustmentRequest[]
  workHistories                WorkHistory[]
  rewards                      Reward[]
  emergencyContacts            EmergencyContact[]
  dependents                   Dependent[]
  timelineEvents               EmployeeTimeline[]
  roleAssignments              UserCustomRoleAssignment[]
  payrollCompany               Organization?                 @relation("PayrollCompanyEmployees", fields: [payrollCompanyId], references: [id])
  leaveBalances                LeaveBalance[]
  leaveRequests                LeaveRequest[]                @relation("LeaveRequestsByUser")
  contracts                    Contract[]
  createdContractAddendums     ContractAddendum[]            @relation("ContractAddendumsCreatedBy")
  createdContractTemplates     ContractTemplate[]            @relation("ContractTemplatesCreatedBy")
  receivedContractExpiryAlerts ContractExpiryDispatch[]      @relation("ContractExpiryDispatchRecipient")
  processedPayrollRecords      PayrollRecord[]               @relation("ProcessedByUser")
  approvedPayrollRecords       PayrollRecord[]               @relation("ApprovedByUser")

  role                 String?
  banned               Boolean?              @default(false)
  banReason            String?
  banExpires           DateTime?
  invitations          Invitation[]
  onboardings          Onboarding[]
  onboardingChecklists OnboardingChecklist[]
  aiChatSessions       AIChatSession[]

  aiChatActiveSessionId String?

  aiCredits         Int       @default(100)
  aiTotalTokensUsed Int       @default(0)
  aiLastResetAt     DateTime?

  @@map("users")
}

// ==================== HỒ SƠ 360° ====================

model WorkHistory {
  id          String    @id @default(cuid())
  userId      String
  company     String
  position    String
  startDate   DateTime
  endDate     DateTime?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("work_histories")
}

model Reward {
  id           String   @id @default(cuid())
  userId       String
  type         String   @default("REWARD") // REWARD | DISCIPLINE
  title        String
  description  String?
  amount       Decimal? @db.Decimal(15, 0)
  decisionDate DateTime
  decisionNo   String?
  status       String   @default("APPROVED") // PENDING | APPROVED | REJECTED
  approvedBy   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("rewards")
}

model EmergencyContact {
  id           String   @id @default(cuid())
  userId       String
  name         String
  relationship String
  phone        String
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("emergency_contacts")
}

model Dependent {
  id           String    @id @default(cuid())
  userId       String
  name         String
  relationship String // SPOUSE | CHILD | PARENT
  dateOfBirth  DateTime?
  nationalId   String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("dependents")
}

model EmployeeTimeline {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime
  type        String // HIRED, PROMOTED, DEPARTMENT_CHANGE, CONTRACT_RENEWED, SALARY_CHANGE, LEAVE, REWARD, DISCIPLINE, TRAINING, RESIGNED
  title       String
  description String?
  metadata    Json?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("employee_timelines")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy       String?
  activeOrganizationId String?

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}

model Organization {
  id                String    @id @default(cuid())
  name              String
  slug              String    @unique
  logo              String?
  metadata          String?
  email             String? // Email công ty
  country           String? // Quốc gia
  agreementAccepted Boolean   @default(false) // Đã đồng ý điều khoản
  agreementDate     DateTime? // Ngày đồng ý điều khoản
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  members           Member[]
  payrollEmployees  User[]    @relation("PayrollCompanyEmployees")

  invitations Invitation[]

  @@map("organizations")
}

model Member {
  id             String       @id @default(cuid())
  userId         String
  organizationId String
  role           String       @default("member")
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@map("members")
}

model Department {
  id                 String          @id @default(cuid())
  name               String
  code               String          @unique
  logo               String?
  description        String?
  parentId           String?
  secondaryParentIds String[]
  managerId          String?
  status             String          @default("ACTIVE")
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  manager            User?           @relation("DeptManager", fields: [managerId], references: [id])
  parent             Department?     @relation("DeptHierarchy", fields: [parentId], references: [id])
  children           Department[]    @relation("DeptHierarchy")
  jobPostings        JobPosting[]
  positions          Position[]
  users              User[]
  payroll_records    PayrollRecord[] @relation("DepartmentToPayrollRecord")
  payrollRecord      PayrollRecord?  @relation("PayrollRecordDepartment")

  @@map("departments")
}

model Position {
  id               String               @id @default(cuid())
  name             String
  code             String               @unique
  authority        String               @default("STAFF") // EXECUTIVE, DIRECTOR, MANAGER, DEPUTY, TEAM_LEAD, STAFF, INTERN
  departmentId     String?
  level            Int                  @default(1) // 1=cao nhất (Giám đốc), 7=thấp nhất (Thực tập)
  description      String?
  parentId         String?
  minSalary        Decimal?             @db.Decimal(15, 0)
  maxSalary        Decimal?             @db.Decimal(15, 0)
  status           String               @default("ACTIVE") // ACTIVE, INACTIVE
  sortOrder        Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @default(now()) @updatedAt
  jobPostings      JobPosting[]
  department       Department?          @relation(fields: [departmentId], references: [id])
  users            User[]
  parent           Position?            @relation("PositionHierarchy", fields: [parentId], references: [id])
  children         Position[]           @relation("PositionHierarchy")
  roleMapping      PositionRoleMapping?
  positionSalaries PositionSalary[]

  @@map("positions")
}

model Shift {
  id                  String            @id @default(cuid())
  name                String
  code                String            @unique
  startTime           String
  endTime             String
  breakMinutes        Int               @default(60)
  lateThreshold       Int               @default(15)
  earlyThreshold      Int               @default(15)
  isDefault           Boolean           @default(false)
  isActive            Boolean           @default(true)
  type                String            @default("FIXED") // "FIXED" | "FLEXIBLE" | "FLEXIBLE_WINDOW"
  checkinWindowStart  String?
  checkinWindowEnd    String?
  checkoutWindowStart String?
  checkoutWindowEnd   String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  attendances         Attendance[]
  shiftAssignments    ShiftAssignment[]
  workCycleEntries    WorkCycleEntry[]

  @@map("shifts")
}

model ShiftAssignment {
  id             String     @id @default(cuid())
  userId         String
  shiftId        String?
  startDate      DateTime   @db.Date
  endDate        DateTime?  @db.Date
  workCycleId    String?
  cycleStartDate DateTime?  @db.Date
  createdAt      DateTime   @default(now())
  shift          Shift?     @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  workCycle      WorkCycle? @relation(fields: [workCycleId], references: [id], onDelete: Cascade)

  @@map("shift_assignments")
}

model Attendance {
  id                String                       @id @default(cuid())
  userId            String
  date              DateTime                     @db.Date
  shiftId           String?
  checkIn           DateTime?
  checkOut          DateTime?
  checkInMethod     String?
  checkOutMethod    String?
  checkInLocation   String?
  checkOutLocation  String?
  checkInPhoto      String?
  checkOutPhoto     String?
  checkInDeviceId   String?
  checkOutDeviceId  String?
  checkInVerified   Boolean                      @default(false)
  checkOutVerified  Boolean                      @default(false)
  workHours         Float?
  overtimeHours     Float?
  lateMinutes       Int                          @default(0)
  earlyMinutes      Int                          @default(0)
  status            String                       @default("PRESENT")
  note              String?
  isLocked          Boolean                      @default(false)
  source            String                       @default("MANUAL")
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  explanation       AttendanceExplanation?
  adjustmentRequest AttendanceAdjustmentRequest?
  shift             Shift?                       @relation(fields: [shiftId], references: [id])
  user              User                         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("attendances")
}

model AttendanceExplanation {
  id             String     @id @default(cuid())
  attendanceId   String     @unique
  type           String     @default("OTHER")
  reason         String
  status         String     @default("PENDING")
  approvedBy     String?
  approvedAt     DateTime?
  rejectedReason String?
  attachment     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  attendance     Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@map("attendance_explanations")
}

model OvertimeRequest {
  id                String    @id @default(cuid())
  userId            String
  requestedBy       String
  date              DateTime  @db.Date
  startTime         String
  endTime           String
  hours             Float
  reason            String
  status            String    @default("PENDING")
  managerApprovedBy String?
  managerApprovedAt DateTime?
  managerNote       String?
  hrApprovedBy      String?
  hrApprovedAt      DateTime?
  hrNote            String?
  rejectedBy        String?
  rejectedAt        DateTime?
  rejectedReason    String?
  rejectedStep      String?
  actualStartTime   String?
  actualEndTime     String?
  actualHours       Float?
  confirmedAt       DateTime?
  coefficient       Float     @default(1.5)
  dayType           String    @default("WEEKDAY")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("overtime_requests")
}

model AttendanceConfig {
  id                   String          @id @default(cuid())
  requireGps           Boolean         @default(true)
  requireWifi          Boolean         @default(false)
  requireSelfie        Boolean         @default(false)
  maxGpsDistanceMeters Int             @default(200)
  earlyCheckinMinutes  Int             @default(60)
  officeLat            Float?
  officeLng            Float?
  standardWorkHours    Float           @default(8)
  standardWorkDays     Int             @default(22)
  otWeekdayCoeff       Float           @default(1.5)
  otWeekendCoeff       Float           @default(2.0)
  otHolidayCoeff       Float           @default(3.0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  wifiWhitelist        WifiWhitelist[]

  @@map("attendance_configs")
}

model WifiWhitelist {
  id       String           @id @default(cuid())
  configId String
  ssid     String
  bssid    String?
  config   AttendanceConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@map("wifi_whitelists")
}

model TimekeeperDevice {
  id        String    @id @default(cuid())
  name      String
  code      String    @unique
  type      String    @default("FINGERPRINT")
  location  String?
  ipAddress String?
  apiKey    String?
  isActive  Boolean   @default(true)
  lastSync  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("timekeeper_devices")
}

model Holiday {
  id                String  @id @default(cuid())
  holidayCalendarId String? // FK đến HolidayCalendar

  name        String
  date        DateTime  @db.Date
  endDate     DateTime? @db.Date
  isRecurring Boolean   @default(false)
  year        Int?
  halfDay     String?   @default("FULL") // FULL | MORNING | AFTERNOON

  holidayCalendar HolidayCalendar? @relation(fields: [holidayCalendarId], references: [id])
  createdAt       DateTime         @default(now())

  @@map("holidays")
}

model WorkCycle {
  id               String            @id @default(cuid())
  name             String
  description      String?
  totalDays        Int
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  shiftAssignments ShiftAssignment[]
  entries          WorkCycleEntry[]

  @@map("work_cycles")
}

model WorkCycleEntry {
  id          String    @id @default(cuid())
  workCycleId String
  dayIndex    Int
  shiftId     String?
  isDayOff    Boolean   @default(false)
  shift       Shift?    @relation(fields: [shiftId], references: [id])
  workCycle   WorkCycle @relation(fields: [workCycleId], references: [id], onDelete: Cascade)

  @@unique([workCycleId, dayIndex])
  @@map("work_cycle_entries")
}

model AttendanceSummary {
  id              String    @id @default(cuid())
  userId          String
  month           Int
  year            Int
  totalWorkDays   Float     @default(0)
  standardDays    Float     @default(22)
  lateDays        Int       @default(0)
  earlyLeaveDays  Int       @default(0)
  absentDays      Float     @default(0)
  leaveDays       Float     @default(0)
  unpaidLeaveDays Float     @default(0)
  holidayDays     Float     @default(0)
  otHoursWeekday  Float     @default(0)
  otHoursWeekend  Float     @default(0)
  otHoursHoliday  Float     @default(0)
  totalOtHours    Float     @default(0)
  totalWorkHours  Float     @default(0)
  isLocked        Boolean   @default(false)
  lockedBy        String?
  lockedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@map("attendance_summaries")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String   @default("")
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id    String  @id @default(cuid())
  key   String  @unique
  value String
  group String?

  @@map("system_settings")
}

model JobPosting {
  id              String      @id @default(cuid())
  title           String
  departmentId    String?
  positionId      String?
  description     String
  requirements    String
  salaryMin       Decimal?    @db.Decimal(15, 0)
  salaryMax       Decimal?    @db.Decimal(15, 0)
  salaryCurrency  String      @default("VND")
  headcount       Int         @default(1)
  employmentType  String      @default("FULL_TIME")
  status          String      @default("DRAFT")
  priority        String      @default("NORMAL")
  deadline        DateTime?
  benefits        String?
  workLocation    String?
  interviewRounds Int         @default(1)
  createdBy       String
  reviewedBy      String?
  reviewedAt      DateTime?
  closedBy        String?
  closedAt        DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  candidates      Candidate[]
  interviews      Interview[]
  department      Department? @relation(fields: [departmentId], references: [id])
  position        Position?   @relation(fields: [positionId], references: [id])

  @@map("job_postings")
}

model Candidate {
  id                      String                    @id @default(cuid())
  jobPostingId            String
  name                    String
  email                   String
  phone                   String?
  gender                  String?
  dateOfBirth             DateTime?
  address                 String?
  cvUrl                   String?
  cvFileName              String?
  linkedinUrl             String?
  portfolioUrl            String?
  source                  String                    @default("WEBSITE")
  sourceDetail            String?
  stage                   String                    @default("APPLIED")
  rating                  Int?                      @default(0)
  rejectionReason         String?
  hiredSalary             Decimal?                  @db.Decimal(15, 0)
  hiredDate               DateTime?
  notes                   String?
  tags                    String[]
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
  CandidateToCandidateTag CandidateToCandidateTag[]
  jobPosting              JobPosting                @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  interviews              Interview[]
  onboarding              Onboarding?               @relation(fields: [onboardingid], references: [id])
  onboardingid            String?

  @@unique([email, jobPostingId])
  @@map("candidates")
}

model CandidateTag {
  id                      String                    @id @default(cuid())
  name                    String                    @unique
  color                   String                    @default("#6366f1")
  createdAt               DateTime                  @default(now())
  CandidateToCandidateTag CandidateToCandidateTag[]

  @@map("candidate_tags")
}

model Interview {
  id               String              @id @default(cuid())
  candidateId      String
  jobPostingId     String
  round            Int                 @default(1)
  type             String              @default("ONSITE")
  method           String              @default("INDIVIDUAL")
  scheduledDate    DateTime
  scheduledTime    String
  endTime          String?
  duration         Int                 @default(60)
  location         String?
  meetingLink      String?
  meetingId        String?
  interviewerIds   String[]
  interviewerNames String[]
  status           String              @default("SCHEDULED")
  result           String?
  score            Int?
  strengths        String?
  weaknesses       String?
  notes            String?
  googleEventId    String?
  calendarSync     Boolean             @default(false)
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  feedbacks        InterviewFeedback[]
  candidate        Candidate           @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobPosting       JobPosting          @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@map("interviews")
}

model InterviewFeedback {
  id             String    @id @default(cuid())
  interviewId    String
  userId         String
  userName       String
  score          Int?
  result         String?
  technicalSkill Int?
  communication  Int?
  problemSolving Int?
  cultureFit     Int?
  strengths      String?
  improvements   String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  interview      Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  @@unique([interviewId, userId])
  @@map("interview_feedbacks")
}

model Asset {
  id            String            @id @default(cuid())
  name          String
  code          String            @unique
  category      String
  status        String            @default("AVAILABLE")
  brand         String?
  model         String?
  serialNumber  String?
  purchaseDate  DateTime?
  purchasePrice Decimal?          @db.Decimal(15, 0)
  warrantyEnd   DateTime?
  location      String?
  description   String?
  createdBy     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  assignments   AssetAssignment[]

  @@index([category])
  @@index([status])
  @@map("assets")
}

model AssetAssignment {
  id             String    @id @default(cuid())
  assetId        String
  userId         String
  assignedBy     String?
  assignDate     DateTime  @default(now())
  expectedReturn DateTime?
  returnDate     DateTime?
  returnedTo     String?
  status         String    @default("ASSIGNED")
  condition      String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  asset          Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@index([userId])
  @@index([status])
  @@map("asset_assignments")
}

model OffboardingTemplate {
  id           String            @id @default(cuid())
  name         String
  description  String?
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tasks        OffboardingTask[]
  offboardings Offboarding[]

  @@map("offboarding_templates")
}

model OffboardingTask {
  id           String              @id @default(cuid())
  templateId   String
  title        String
  description  String?
  category     String              @default("GENERAL")
  assigneeRole String?
  dueDays      Int                 @default(7)
  sortOrder    Int                 @default(0)
  isRequired   Boolean             @default(true)
  template     OffboardingTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("offboarding_tasks")
}

model Offboarding {
  id                String                 @id @default(cuid())
  userId            String
  templateId        String?
  resignDate        DateTime               @db.Date
