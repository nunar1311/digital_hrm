// ==================== ATTENDANCE APPROVAL PROCESS ====================

model AttendanceApprovalProcess {
  id                    String                   @id @default(cuid())
  name                  String                   @default("Quy trình duyệt chấm công")
  isActive              Boolean                  @default(true)
  // Advanced settings
  sendEmailReminder     Boolean                  @default(false)
  skipDuplicateApprover Boolean                  @default(true)
  skipSelfApprover      Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  steps                 AttendanceApprovalStep[]

  @@map("attendance_approval_processes")
}

model AttendanceApprovalStep {
  id        String                    @id @default(cuid())
  processId String
  process   AttendanceApprovalProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  stepOrder Int
  stepType  String // "APPROVER" | "CONDITION"

  // Loại người duyệt (khi stepType = APPROVER)
  approverType      String? // "DIRECT_MANAGER" | "MANAGER_LEVEL" | "DEPT_HEAD" | "CUSTOM_LIST"
  managerLevel      Int? // Cấp quản lý (1, 2, 3...)
  approvalMethod    String? // "ALL_MUST_APPROVE" | "FIRST_APPROVES"
  customApproverIds String? // JSON array of user IDs

  // Điều kiện (khi stepType = CONDITION)
  conditionType     String? // "DEPARTMENT" | "WORKGROUP" | "PAYROLL_COMPANY" | "OTHER"
  conditionField    String?
  conditionOperator String?
  conditionValues   String? // JSON array of values

  // Priority cho conditions (null = "OTHER" fallback)
  priority Int?

  // Điều kiện bỏ qua
  skipIfNoApproverFound Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([processId])
  @@index([stepOrder])
  @@map("attendance_approval_steps")
}

model AttendanceAdjustmentRequest {
  id           String     @id @default(cuid())
  attendanceId String     @unique
  attendance   Attendance @relation(fields: [attendanceId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])

  // Thông tin điều chỉnh
  date         DateTime @db.Date
  checkInTime  String?
  checkOutTime String?
  reason       String
  attachment   String?

  // Trạng thái & luồng duyệt
  status      String @default("PENDING") // PENDING | APPROVED | REJECTED | AUTO_APPROVED | CANCELLED
  currentStep Int    @default(1)

  // Approval chain
  approvalChain Json? // [{stepOrder, approverId, approverName, action, actionAt, note}]

  // Rejection info
  rejectedBy     String?
  rejectedAt     DateTime?
  rejectedReason String?

  // Auto-approve reason
  autoApprovedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("attendance_adjustment_requests")
}

// =============================================
// ROLES - Vai trò cố định + tùy chỉnh
// =============================================

model Role {
  id          String   @id @default(cuid())
  key         String   @unique // Mã vai trò: SUPER_ADMIN, HR_MANAGER, custom_xxx
  name        String // Tên hiển thị
  description String?
  roleType    String   @default("CUSTOM") // FIXED | CUSTOM
  isActive    Boolean  @default(true)
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userAssignments UserCustomRoleAssignment[]
  rolePermissions RolePermission[]

  @@index([roleType])
  @@index([isActive])
  @@map("roles")
}

// Lưu các permission key dưới dạng chuỗi (đồng bộ với enum Permission)

model PermissionKey {
  id    String @id @default(cuid())
  key   String @unique
  label String
  group String

  rolePermissions RolePermission[]

  @@map("permission_keys")
}

// Bảng trung gian: Role <-> PermissionKey (nhiều-nhiều)

model RolePermission {
  id            String @id @default(cuid())
  roleId        String
  permissionKey String

  role       Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission PermissionKey @relation(fields: [permissionKey], references: [key])

  @@unique([roleId, permissionKey])
  @@index([roleId])
  @@index([permissionKey])
  @@map("role_permissions")
}

// Gán User <-> Role (nhiều role per user)

model UserCustomRoleAssignment {
  id         String   @id @default(cuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_custom_role_assignments")
}

// =============================================
// =============================================
// LEAVE - Quản lý nghỉ phép (đơn giản)
// =============================================

// Loại ngày nghỉ

model LeaveType {
  id          String  @id @default(cuid())
  name        String // "Phép năm", "Nghỉ ốm", "Nghỉ thai sản"
  description String?
  sortOrder   Int     @default(0)
  isPaidLeave Boolean @default(true) // Nghỉ có lương
  defaultDays Float   @default(12) // Số ngày phép mặc định/năm
  isActive    Boolean @default(true)

  // Thâm niên
  applySeniorityBonus Boolean @default(false) // Có tính cộng thêm ngày theo thâm niên không

  // Carry-over cuối năm
  maxCarryOverDays Float? // null = không cho carry-over; 0 = chuyển tất; n = tối đa n ngày

  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave_types")
}

// Số dư ngày nghỉ của nhân viên

model LeaveBalance {
  id          String @id @default(cuid())
  userId      String
  leaveTypeId String

  totalDays    Float @default(0) // Tổng số ngày được cấp trong kỳ
  usedDays     Float @default(0) // Số ngày đã dùng
  pendingDays  Float @default(0) // Số ngày đang chờ duyệt
  seniorityDays Float @default(0) // Ngày cộng thêm do thâm niên
  carryOverDays Float @default(0) // Ngày phép chuyển từ năm trước
  policyYear   Int   // Năm

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaveType     LeaveType      @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  leaveRequests LeaveRequest[]

  @@unique([userId, leaveTypeId, policyYear])
  @@index([userId])
  @@index([leaveTypeId])
  @@map("leave_balances")
}

// Đơn xin nghỉ

model LeaveRequest {
  id             String  @id @default(cuid())
  userId         String
  leaveTypeId    String
  leaveBalanceId String?

  startDate DateTime
  endDate   DateTime
  totalDays Float // Số ngày nghỉ
  reason    String?
  status    String   @default("PENDING") // PENDING | APPROVED | REJECTED | CANCELLED

  documentUrl     String? // URL tài liệu chứng minh
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String?

  // ── Luồng duyệt đa cấp ──
  approvalChain   Json?   // Array<ApprovalStepRecord> - lưu trạng thái từng bước
  currentStep     Int     @default(0) // Bước duyệt hiện tại (0 = chưa có luồng)
  leaveApprovalProcessId String? // Quy trình duyệt được áp dụng

  leaveBalance         LeaveBalance?         @relation(fields: [leaveBalanceId], references: [id], onDelete: SetNull)
  leaveApprovalProcess LeaveApprovalProcess? @relation(fields: [leaveApprovalProcessId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation("LeaveRequestsByUser", fields: [userId], references: [id], onDelete: Cascade)
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([leaveTypeId])
  @@index([status])
  @@map("leave_requests")
}

// Quy tắc cộng phép theo thâm niên

model LeaveSeniorityRule {
  id        String   @id @default(cuid())
  minYears  Int // Số năm thâm niên tối thiểu (vd: 5 = từ 5 năm trở lên)
  maxYears  Int? // Số năm tối đa (null = không giới hạn)
  bonusDays Float // Số ngày cộng thêm
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave_seniority_rules")
}

// Quy trình duyệt nghỉ phép đa cấp

model LeaveApprovalProcess {
  id          String  @id @default(cuid())
  name        String
  description String?
  isActive    Boolean @default(true)
  isDefault   Boolean @default(false) // Quy trình mặc định cho tất cả đơn

  // Cài đặt nâng cao
  skipDuplicateApprover Boolean @default(true)
  skipSelfApprover      Boolean @default(true)
  sendEmailReminder     Boolean @default(false)

  // Các bước duyệt (JSON - tương tự AttendanceApprovalProcess)
  steps Json? // Array<ApprovalStep>

  leaveRequests LeaveRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave_approval_processes")
}

// Bảng trung gian: Position <-> Role (mỗi Position có một Role mặc định)

model PositionRoleMapping {
  id         String   @id @default(cuid())
  positionId String   @unique
  roleKey    String
  isDefault  Boolean  @default(true)
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("position_role_mappings")
}

// =============================================
// POSITION SALARY - Lương cơ bản theo chức vụ
// =============================================

model PositionSalary {
  id            String   @id @default(cuid())
  positionId    String
  salaryGrade   String   @default("A") // A, B, C, D... (bậc lương)
  baseSalary    Decimal  @db.Decimal(15, 0)
  description   String?
  isActive      Boolean  @default(true)
  effectiveDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  position      Position @relation(fields: [positionId], references: [id], onDelete: Cascade)

  @@unique([positionId, salaryGrade])
  @@index([positionId])
  @@index([isActive])
  @@map("position_salaries")
}

// ==================== HỢP ĐỒNG LAO ĐỘNG ====================

model Contract {
  id              String    @id @default(cuid())
  userId          String
  contractNumber  String    @unique
  title           String
  contractTypeId  String?
  templateId      String?
  startDate       DateTime
  endDate         DateTime?
  signedDate      DateTime?
  status          String    @default("DRAFT") // DRAFT, PENDING, ACTIVE, EXPIRED, TERMINATED
  salary          Float?
  currency        String    @default("VND")
  probationSalary Float?
  fileUrl         String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user             User                     @relation(fields: [userId], references: [id])
  contractType     ContractType?            @relation(fields: [contractTypeId], references: [id])
  template         ContractTemplate?        @relation(fields: [templateId], references: [id])
  addendums        ContractAddendum[]
  expiryDispatches ContractExpiryDispatch[]

  @@index([userId])
  @@index([status, endDate])
  @@index([templateId])
  @@map("contracts")
}

model ContractType {
  id             String   @id @default(cuid())
  name           String // "Hợp đồng thử việc", "Hợp đồng có thời hạn", ...
  durationMonths Int? // null = không thời hạn
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  contracts Contract[]

  @@map("contract_types")
}

model ContractTemplate {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  content     String
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  creator   User?      @relation("ContractTemplatesCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  contracts Contract[]

  @@index([isActive])
  @@map("contract_templates")
}

model ContractAddendum {
  id            String    @id @default(cuid())
  contractId    String
  addendumType  String // EXTENSION | SALARY_CHANGE
  title         String
  effectiveDate DateTime
  oldEndDate    DateTime?
  newEndDate    DateTime?
  oldSalary     Float?
  newSalary     Float?
  reason        String?
  notes         String?
  createdBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  creator  User?    @relation("ContractAddendumsCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([contractId, effectiveDate])
  @@index([addendumType])
  @@map("contract_addendums")
}

model ContractExpiryDispatch {
  id              String   @id @default(cuid())
  contractId      String
  recipientId     String
  reminderDays    Int
  contractEndDate DateTime
  source          String? // scheduler | page_open
  sentAt          DateTime @default(now())

  contract  Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  recipient User     @relation("ContractExpiryDispatchRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([contractId, recipientId, reminderDays, contractEndDate])
  @@index([recipientId, sentAt])
  @@map("contract_expiry_dispatches")
}

// Lịch nghỉ lễ - nhóm ngày lễ theo quốc gia/năm

model HolidayCalendar {
  id          String  @id @default(cuid())
  name        String // "Lịch nghỉ lễ Việt Nam 2025"
  description String?
  year        Int // 2025, 2026...
  country     String? // "Vietnam", "Singapore", ...
  isDefault   Boolean @default(false) // Lịch mặc định
  isActive    Boolean @default(true)

  holidays Holiday[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("holiday_calendars")
}

model Invitation {
  id             String       @id
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email          String
  role           String?
  status         String       @default("pending")
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  inviterId      String
  user           User         @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@map("invitation")
}

// ==================== AI DASHBOARD ====================

model AIDashboardSummary {
  id          String   @id @default(cuid())
  date        DateTime @db.Date // Ngày tạo báo cáo (để tìm kiếm theo ngày)
  detailLevel String   @default("standard")
  content     String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date, detailLevel])
  @@index([date])
  @@map("ai_dashboard_summaries")
}

model AIChatSession {
  id        String          @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIChatMessage[]

  @@index([userId])
  @@map("ai_chat_sessions")
}

model AIChatMessage {
  id        String        @id @default(cuid())
  sessionId String
  role      String        // system | user | assistant
  content   String
  metadata  Json?         // To store attachments, tool calls, and actions
  createdAt DateTime      @default(now())
  session   AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("ai_chat_messages")
}
