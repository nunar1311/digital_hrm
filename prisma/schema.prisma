  userId    String
  type      String // ATTENDANCE, LEAVE, PAYROLL, OVERTIME, SYSTEM, etc.
  title     String
  content   String
  link      String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  priority  String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id                       String   @id @default(cuid())
  userId                   String   @unique
  // Email channel
  emailEnabled             Boolean  @default(true)
  quietHoursEnabled        Boolean  @default(false)
  quietHoursStart          String? // "22:00"
  quietHoursEnd            String? // "08:00"
  notificationTypes        String[] @default([]) // Email notification types (legacy - keeping for backward compatibility)
  // Email channel - new separate fields (matching inbox pattern)
  emailNotificationTypes   String[] @default([])
  emailQuietHoursEnabled   Boolean  @default(false)
  emailQuietHoursStart     String?
  emailQuietHoursEnd       String?
  // Browser channel
  browserEnabled           Boolean  @default(true)
  browserSoundEnabled      Boolean  @default(true)
  browserNotificationTypes String[] @default([])
  browserQuietHoursEnabled Boolean  @default(false)
  browserQuietHoursStart   String?
  browserQuietHoursEnd     String?
  // Inbox channel (separate from email - using new fields)
  inboxNotificationTypes   String[] @default([])
  inboxQuietHoursEnabled   Boolean  @default(false)
  inboxQuietHoursStart     String? // "22:00"
  inboxQuietHoursEnd       String? // "08:00"
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  users                    User[]

  @@map("notification_preferences")
}

model EmailTemplate {
